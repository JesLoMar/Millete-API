# =============================================
# MILETE - ENVIRONMENT VARIABLES TEMPLATE
# Rename this file to .env and fill in your real values
# NEVER commit .env to the repository
# =============================================

# Spring Boot profile
SPRING_PROFILES_ACTIVE=prod

# =============================================
# DATABASE (PostgreSQL)
# =============================================
DATABASE_URL=jdbc:postgresql://localhost:5432/millete
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here

# =============================================
# EMAIL (SMTP)
# =============================================
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password_or_api_key
MAIL_FROM=noreply@yourdomain.com

# =============================================
# FRONTEND
# =============================================
FRONTEND_URL=http://localhost:5173

# =============================================
# JWT SECURITY
# Generate a secure key with: openssl rand -base64 64
# Minimum 256 bits (32 characters) required
# =============================================
JWT_SECRET=generate_a_secure_key_at_least_256_bits_long_using_openssl
JWT_EXPIRATION=43200000

# =============================================
# JASYPT (Optional - only if using encrypted values)
# Uncomment and set if you want to encrypt sensitive values
# =============================================
# JASYPT_ENCRYPTOR_PASSWORD=your_master_encryption_key_here